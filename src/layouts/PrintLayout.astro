---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} · immogutachter360°</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green: #8CBC94;
      --ink: #181b31;
      --mute: rgba(24,27,49,0.55);
      --line: #E5E1D8;
      --cream: #FAF6F0;
    }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      color: var(--ink);
      background: #fff;
      max-width: 800px;
      margin: 0 auto;
      padding: 2.5rem 2rem;
      line-height: 1.6;
    }

    /* ── Brand header ── */
    .brand-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 2px solid var(--green);
      padding-bottom: 1.25rem;
      margin-bottom: 2rem;
    }

    .brand-header img { height: 38px; width: auto; }

    .brand-contact {
      text-align: right;
      font-size: 0.75rem;
      color: var(--mute);
      line-height: 1.5;
    }

    /* ── Screen-only actions ── */
    .screen-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
      margin-bottom: 2.5rem;
    }

    .btn-print {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--green);
      color: var(--ink);
      font-family: 'Inter', sans-serif;
      font-size: 0.875rem;
      font-weight: 600;
      padding: 0.625rem 1.25rem;
      border-radius: 999px;
      border: none;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-print:hover { background: #6fa878; }

    .link-back {
      font-size: 0.875rem;
      color: var(--mute);
      text-decoration: none;
      transition: color 0.2s;
    }
    .link-back:hover { color: var(--ink); }

    /* ── Page title ── */
    .page-title {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 1.75rem;
      font-weight: 300;
      line-height: 1.2;
      margin-bottom: 0.375rem;
    }

    .page-subtitle {
      font-size: 0.9rem;
      color: var(--mute);
      margin-bottom: 2rem;
    }

    /* ── Checklist sections ── */
    .checklist-section {
      margin-top: 2rem;
      break-inside: avoid;
    }

    .checklist-section-title {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 1rem;
      font-weight: 400;
      color: var(--green);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      border-bottom: 1px solid var(--line);
      padding-bottom: 0.5rem;
      margin-bottom: 1rem;
    }

    /* ── Checklist items ── */
    .checklist-item {
      display: flex;
      gap: 0.875rem;
      margin-bottom: 0.875rem;
      break-inside: avoid;
    }

    .checkbox {
      flex-shrink: 0;
      width: 17px;
      height: 17px;
      border: 1.5px solid var(--green);
      border-radius: 3px;
      margin-top: 3px;
      background: white;
    }

    .item-text { font-size: 0.9rem; }

    .item-hint {
      font-size: 0.775rem;
      color: var(--mute);
      margin-top: 2px;
      font-style: italic;
    }

    /* ── Print footer ── */
    .print-footer {
      margin-top: 3rem;
      padding-top: 1rem;
      border-top: 1px solid var(--line);
      font-size: 0.7rem;
      color: var(--mute);
      display: flex;
      justify-content: space-between;
    }

    /* ── CTA box (screen only) ── */
    .cta-box {
      margin-top: 2.5rem;
      background: var(--cream);
      border: 1px solid var(--line);
      border-left: 3px solid var(--green);
      border-radius: 8px;
      padding: 1.25rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .cta-box-text { font-size: 0.9rem; color: var(--mute); }
    .cta-box-text strong { color: var(--ink); }

    .btn-cta {
      display: inline-flex;
      align-items: center;
      background: var(--ink);
      color: white;
      font-family: 'Inter', sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      padding: 0.5rem 1.1rem;
      border-radius: 999px;
      text-decoration: none;
      white-space: nowrap;
    }
    .btn-cta:hover { background: #242840; }

    /* ── Print overrides ── */
    @media print {
      body { padding: 0; max-width: none; }
      .no-print { display: none !important; }
      @page { margin: 1.5cm; size: A4; }
      .checklist-section { break-inside: avoid; }
      .checklist-item { break-inside: avoid; }
    }

    @media (max-width: 600px) {
      body { padding: 1.5rem 1rem; }
      .brand-header { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
      .brand-contact { text-align: left; }
    }
  </style>
</head>
<body>

  <!-- Brand header -->
  <header class="brand-header">
    <img src="/logo_immo.png" alt="immogutachter360°" />
    <div class="brand-contact">
      info@immogutachter360.de &nbsp;·&nbsp; +49 174 3012443<br/>
      Metzer Str. 70 &nbsp;·&nbsp; 40476 Düsseldorf
    </div>
  </header>

  <!-- Screen-only: Print + Back buttons -->
  <div class="screen-actions no-print">
    <button class="btn-print" onclick="window.print()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
      Als PDF speichern
    </button>
    <a href="/faq" class="link-back">← Zurück zur FAQ</a>
  </div>

  <!-- Page title -->
  <h1 class="page-title">{title}</h1>
  {subtitle && <p class="page-subtitle">{subtitle}</p>}

  <!-- Content slot -->
  <slot />

  <!-- Screen-only: CTA box -->
  <div class="cta-box no-print">
    <p class="cta-box-text">
      <strong>Unterlagen zusammen? </strong>
      Jetzt kostenlose Ersteinschätzung anfragen — wir melden uns innerhalb von 24 Stunden.
    </p>
    <a href="/kontakt" class="btn-cta">Kostenlose Anfrage →</a>
  </div>

  <!-- Print footer -->
  <footer class="print-footer">
    <span>immogutachter360° · Erdem Tanrikulu · DEKRA-zertifizierter Sachverständiger</span>
    <span>www.immogutachter360.de</span>
  </footer>

</body>
</html>
