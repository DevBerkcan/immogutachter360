---
interface BreadcrumbItem {
  name: string;
  href: string;
}
interface Props {
  items: BreadcrumbItem[];
  class?: string;
}
const { items, class: className = '' } = Astro.props;
---
<nav aria-label="Breadcrumb" class:list={['mb-6', className]}>
  <ol class="flex flex-wrap items-center gap-x-1.5 gap-y-1 text-sm" style="color: var(--color-mute)">
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && (
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true" style="opacity: 0.4">
            <path d="M3.5 2l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        )}
        {i < items.length - 1 ? (
          <a href={item.href} class="transition-colors hover:text-green">{item.name}</a>
        ) : (
          <span aria-current="page" style="color: var(--color-ink)">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
