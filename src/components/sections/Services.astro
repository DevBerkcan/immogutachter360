---
import { SERVICES } from '~/lib/services';
import ServiceCard from '~/components/sections/ServiceCard.tsx';

const bento = SERVICES.slice(0, 3);
const rest  = SERVICES.slice(3);
---
<section id="leistungen" class="section-y bg-cream">
  <div class="container-x">

    <div class="max-w-2xl">
      <p class="eyebrow">Leistungen</p>
      <h2 class="display-2 mt-4">
        Gutachten für jede Lebenslage —<br/>
        <span class="italic text-green">präzise, anerkannt, Festpreis.</span>
      </h2>
      <p class="mt-6 text-lg text-mute">
        Von der schnellen Marktwerteinschätzung bis zum gerichtsfesten Vollgutachten. Wählen Sie die Leistung, die zu Ihrer Situation passt.
      </p>
    </div>

    {/* Bento top-3: editorial asymmetric layout */}
    <div class="mt-16 grid gap-4 md:grid-cols-12">
      <div class="md:col-span-7">
        <ServiceCard client:visible service={bento[0]} index={0} />
      </div>
      <div class="md:col-span-5">
        <ServiceCard client:visible service={bento[1]} index={1} />
      </div>
      <div class="md:col-span-12">
        <ServiceCard client:visible service={bento[2]} index={2} />
      </div>
    </div>

    {/* Regular 4-col grid for remaining services */}
    {rest.length > 0 && (
      <div class="mt-4 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {rest.map((s, i) => (
          <ServiceCard client:visible service={s} index={i + 3} />
        ))}
      </div>
    )}

    <div class="mt-12 text-center">
      <a href="/leistungen" class="btn-secondary">Alle Leistungen ansehen →</a>
    </div>
  </div>
</section>
