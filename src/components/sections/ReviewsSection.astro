---
---
<section class="section-y bg-cream">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow justify-center">Kundenbewertungen</p>
      <h2 class="display-2 mt-4">
        Was unsere Kunden <span class="italic text-green">sagen.</span>
      </h2>
      <p class="mt-4 text-lg leading-relaxed" style="color: var(--color-mute)">
        Über 500 abgeschlossene Gutachten — lesen Sie, was Eigentümer, Erben und Käufer über unsere Arbeit berichten.
      </p>
    </div>

    {/* ProvenExpert Landing-Page-Widget — consent-gesteuert (§ 25 TDDDG) */}
    <div class="mt-14" id="pe-reviews-wrapper">
      <div id="pewl"></div>

      {/* Platzhalter bis Einwilligung gegeben */}
      <div id="pe-consent-placeholder" class="hidden">
        <div class="grid gap-6 md:grid-cols-3">
          {[
            { quote: 'Die Beratung war professionell, die Kommunikation transparent und das Ergebnis sehr zufriedenstellend.', author: 'Markus H.', role: 'Privatverkauf, Düsseldorf' },
            { quote: 'Von der ersten Kontaktaufnahme bis zur finalen Bewertung war der gesamte Prozess reibungslos und effizient.', author: 'Sabine W.', role: 'Erbschaftsangelegenheit' },
            { quote: 'Das Gutachten wurde gründlich und gewissenhaft erstellt. Zu jeder Zeit fühlte ich mich bestens informiert.', author: 'David B.', role: 'Verkehrswertgutachten, Düsseldorf' },
          ].map(t => (
            <div class="card flex flex-col gap-4">
              <div class="flex gap-0.5">
                {Array.from({ length: 5 }).map(() => (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-green">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </div>
              <p class="flex-1 text-lg leading-relaxed" style="color: var(--color-mute)">{t.quote}</p>
              <div>
                <p class="font-medium text-ink">{t.author}</p>
                <p class="text-sm" style="color: var(--color-mute)">{t.role}</p>
              </div>
            </div>
          ))}
        </div>
        <p class="mt-6 text-center text-xs" style="color: var(--color-mute); opacity: 0.65">
          Alle Bewertungen auf{' '}
          <button
            onclick="window.__showCookieBanner && window.__showCookieBanner()"
            class="underline hover:text-ink transition-colors"
          >
            ProvenExpert anzeigen (Einwilligung erforderlich)
          </button>
        </p>
      </div>
    </div>

    <div class="mt-10 text-center">
      <a href="/referenzen" class="link-underline text-sm font-medium">Alle Referenzen & Fallstudien ansehen →</a>
    </div>
  </div>
</section>

<script>
  function loadPEWidget() {
    var placeholder = document.getElementById('pe-consent-placeholder');
    if (placeholder) placeholder.style.display = 'none';

    var pewl = document.getElementById('pewl');
    if (!pewl || pewl.dataset.loaded) return;
    pewl.dataset.loaded = '1';

    var pw = document.createElement('script');
    pw.async = true;
    pw.src =
      'https://www.provenexpert.com/widget/landing/24TZkWaph9TZ2Lwp0RmZjLwpjZ3AlVKA/?feedback=1&avatar=1&competence=1&style=white';
    pewl.appendChild(pw);
  }

  function hasValidConsent() {
    var c = localStorage.getItem('cookie-consent');
    var ts = parseInt(localStorage.getItem('cookie-consent-ts') || '0', 10);
    return c === 'all' && Date.now() - ts < 365 * 24 * 60 * 60 * 1000;
  }

  function init() {
    if (hasValidConsent()) {
      loadPEWidget();
    } else {
      var placeholder = document.getElementById('pe-consent-placeholder');
      if (placeholder) placeholder.style.display = 'block';
    }
  }

  init();

  window.addEventListener('cookie-consent-update', function (e: Event) {
    var ev = e as CustomEvent;
    if (ev.detail && ev.detail.type === 'all') loadPEWidget();
  });

  document.addEventListener('astro:page-load', function () {
    var pewl = document.getElementById('pewl');
    if (pewl) delete (pewl as HTMLElement & { dataset: DOMStringMap }).dataset.loaded;
    init();
  });
</script>
