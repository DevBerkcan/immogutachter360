---
import { SITE } from '~/lib/site';
const success = Astro.url.searchParams.get('success') === '1';
---
<section class="bg-ink text-paper section-y" data-final-cta>
  <div class="container-x grid gap-12 lg:grid-cols-2 lg:items-center">
    <div>
      <p class="eyebrow">Bereit für Klarheit?</p>
      <h2 class="display-2 mt-4 text-paper">Kostenlose Ersteinschätzung.<br/><span class="italic text-green">Antwort in 24 Stunden.</span></h2>
      <p class="mt-8 text-lg text-paper/70 max-w-md">Schildern Sie uns Ihr Anliegen — wir melden uns persönlich mit einer ersten Einschätzung und einem Festpreisangebot.</p>
      <div class="mt-10 space-y-3">
        <a href={SITE.phoneHref} class="block text-paper hover:text-green transition-colors">📞 {SITE.phone}</a>
        <a href={`mailto:${SITE.email}`} class="block text-paper hover:text-green transition-colors">✉ {SITE.email}</a>
        <a href={SITE.whatsapp} class="block text-paper hover:text-green transition-colors">💬 WhatsApp</a>
      </div>
    </div>
    {success ? (
      <div class="rounded-2xl bg-paper p-8 text-ink text-center">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-success/10">
          <svg class="h-8 w-8 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h3 class="font-display text-2xl">Anfrage eingegangen!</h3>
        <p class="mt-3 text-mute">Wir melden uns persönlich innerhalb von 24 Stunden bei Ihnen.</p>
        <a href="/" class="btn-primary mt-6 inline-flex">Zurück zur Startseite</a>
      </div>
    ) : (
      <form class="rounded-2xl bg-paper p-8 text-ink" action="/api/contact" method="POST">
        <div class="space-y-4">
          <div>
            <label class="text-xs uppercase tracking-[0.2em] text-mute">Name *</label>
            <input required name="name" class="mt-2 w-full border-b border-line bg-transparent py-2 outline-none transition-colors focus:border-green" />
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="text-xs uppercase tracking-[0.2em] text-mute">E-Mail *</label>
              <input required type="email" name="email" class="mt-2 w-full border-b border-line bg-transparent py-2 outline-none transition-colors focus:border-green" />
            </div>
            <div>
              <label class="text-xs uppercase tracking-[0.2em] text-mute">Telefon</label>
              <input name="phone" class="mt-2 w-full border-b border-line bg-transparent py-2 outline-none transition-colors focus:border-green" />
            </div>
          </div>
          <div>
            <label class="text-xs uppercase tracking-[0.2em] text-mute">Anlass</label>
            <select name="reason" class="mt-2 w-full border-b border-line bg-transparent py-2 outline-none focus:border-green">
              <option>Verkauf</option>
              <option>Kauf</option>
              <option>Erbe</option>
              <option>Scheidung</option>
              <option>Steuer</option>
              <option>Versicherung</option>
              <option>Anderes</option>
            </select>
          </div>
          <div>
            <label class="text-xs uppercase tracking-[0.2em] text-mute">Nachricht</label>
            <textarea name="message" rows="3" class="mt-2 w-full border-b border-line bg-transparent py-2 outline-none focus:border-green resize-none"></textarea>
          </div>
          <label class="flex items-start gap-3 text-xs text-mute cursor-pointer">
            <input type="checkbox" required name="consent" class="mt-1" />
            <span>Ich stimme der Datenverarbeitung zu. <a href="/datenschutz" class="underline hover:text-green">Datenschutzerklärung</a></span>
          </label>
          <button type="submit" class="btn-primary w-full">Anfrage absenden →</button>
        </div>
      </form>
    )}
  </div>
</section>
