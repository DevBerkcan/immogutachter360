---
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
{posts.length > 0 && (
  <section class="section-y bg-paper">
    <div class="container-x">
      <div class="flex items-end justify-between">
        <div>
          <p class="eyebrow">Aktuelles</p>
          <h2 class="display-2 mt-4">Fachwissen für<br/><span class="italic text-green">Eigentümer.</span></h2>
        </div>
        <a href="/blog" class="hidden link-underline text-sm font-medium md:inline-flex">Alle Artikel →</a>
      </div>
      <div class="mt-16 grid gap-8 md:grid-cols-3">
        {posts.map((p) => (
          <a href={`/blog/${p.id.replace(/\.mdx?$/, '')}`} class="card card-hover group block h-full">
            <div class="flex items-center gap-3 text-xs">
              <span class="rounded-full px-3 py-1 text-green" style="background-color: rgba(140,188,148,0.12)">{p.data.category}</span>
              <time class="text-mute">{p.data.date.toLocaleDateString('de-DE')}</time>
            </div>
            <h3 class="mt-6 font-display text-2xl group-hover:text-green transition-colors">{p.data.title}</h3>
            <p class="mt-3 text-mute text-sm leading-relaxed line-clamp-3">{p.data.description}</p>
            <span class="mt-6 inline-flex items-center gap-2 text-sm text-green">Weiterlesen →</span>
          </a>
        ))}
      </div>
      <div class="mt-10 md:hidden text-center">
        <a href="/blog" class="btn-secondary">Alle Artikel</a>
      </div>
    </div>
  </section>
)}
