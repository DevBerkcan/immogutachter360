---
---
<section class="section-y bg-paper overflow-hidden">
  <div class="container-x">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">

      {/* Text — links */}
      <div>
        <p class="eyebrow">Einblick in unsere Arbeit</p>
        <h2 class="display-2 mt-4">
          Wie ein Gutachten<br/>
          <span class="italic text-green">wirklich entsteht.</span>
        </h2>
        <p class="mt-6 text-xl leading-relaxed" style="color: var(--color-mute)">
          Von der ersten Besichtigung bis zum rechtssicheren Gutachten —
          sehen Sie unseren Prozess im Video.
        </p>
      </div>

      {/* Video — rechts */}
      <div class="mt-10 lg:mt-0">
        <div class="relative" style="aspect-ratio: 16/9">

          {/* Dekorativer Offset-Rahmen */}
          <div
            class="absolute -bottom-4 -right-4 h-full w-full rounded-2xl"
            style="background: rgba(140,188,148,0.08); border: 1px solid rgba(140,188,148,0.2)"
            aria-hidden="true"
          ></div>

          {/* Video — Platzhalter bis /video-intro.mp4 in public/ abgelegt wird */}
          <div class="absolute inset-0 overflow-hidden rounded-2xl shadow-2xl bg-cream flex items-center justify-center">
            <div class="text-center p-8">
              <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-green/10">
                <svg class="h-8 w-8 text-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
                </svg>
              </div>
              <p class="font-display text-lg text-ink">Video-Einblick</p>
              <p class="mt-2 text-sm" style="color: var(--color-mute)">Unser Prozess im Film — demnächst verfügbar</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>
