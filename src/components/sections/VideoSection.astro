---
---
<section class="section-y bg-paper overflow-hidden">
  <div class="container-x">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">

      {/* Text — links */}
      <div>
        <p class="eyebrow">Einblick in unsere Arbeit</p>
        <h2 class="display-2 mt-4">
          Wie ein Gutachten<br/>
          <span class="italic text-green">wirklich entsteht.</span>
        </h2>
        <p class="mt-6 text-xl leading-relaxed" style="color: var(--color-mute)">
          Von der ersten Abstimmung bis zum rechtssicheren Gutachten —
          unser bewährter Prozess auf einen Blick.
        </p>
      </div>

      {/* Prozessgrafik — rechts */}
      <div class="mt-10 lg:mt-0">
        <div class="relative" style="aspect-ratio: 16/9">

          {/* Dekorativer Offset-Rahmen */}
          <div
            class="absolute -bottom-4 -right-4 h-full w-full rounded-2xl"
            style="background: rgba(140,188,148,0.08); border: 1px solid rgba(140,188,148,0.2)"
            aria-hidden="true"
          ></div>

          {/* Prozessgrafik */}
          <div class="absolute inset-0 overflow-hidden rounded-2xl shadow-2xl">
            <img
              class="h-full w-full object-cover"
              src="/immobilienbewertung-prozess.png"
              alt="Der 7-Schritte-Prozess von immogutachter360 zur Immobilienbewertung"
              loading="lazy"
              decoding="async"
            />
          </div>

        </div>
      </div>

    </div>
  </div>
</section>
