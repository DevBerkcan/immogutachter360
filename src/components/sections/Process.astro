---
import ProcessScroll from '~/components/sections/ProcessScroll.tsx';
---
<section class="bg-charcoal text-paper">
  <div class="container-x py-20 md:py-32 lg:py-0">
    <div class="max-w-2xl py-20 md:py-32 lg:py-40">
      <p class="eyebrow" style="color: #8CBC94">Prozess</p>
      <h2 class="display-2 mt-4 text-paper">So läuft Ihr Gutachten ab.</h2>
      <p class="mt-6 text-lg leading-relaxed" style="color: rgba(255,255,255,0.65)">Klar strukturiert, transparent kommuniziert. Vom ersten Kontakt bis zur Übergabe.</p>
    </div>
    <ProcessScroll client:visible />
  </div>
</section>
