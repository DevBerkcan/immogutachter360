---
import ProcessScroll from '~/components/sections/ProcessScroll.tsx';
---
<section class="bg-charcoal text-paper" data-header-dark>
  <div class="container-x py-20 md:py-32">
    <div class="max-w-2xl">
      <p class="eyebrow" style="color: #8CBC94">Prozess</p>
      <h2 class="display-2 mt-4 text-paper">Von der Anfrage bis zum fertigen Gutachten.</h2>
      <p class="mt-6 text-lg leading-relaxed" style="color: rgba(255,255,255,0.65)">Klar strukturiert, transparent kommuniziert und ohne unnötige Wartezeiten.</p>
    </div>
    <ProcessScroll client:visible />
  </div>
</section>
