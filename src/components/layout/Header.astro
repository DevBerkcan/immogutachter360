---
import { NAV, SITE } from '~/lib/site';
const path = Astro.url.pathname;
---
<style>
  #site-header[data-theme="dark"] nav a {
    color: rgba(250, 246, 240, 0.8);
  }
  #site-header[data-theme="dark"] nav a:hover,
  #site-header[data-theme="dark"] nav a.text-green {
    color: #8CBC94;
  }
  #site-header[data-theme="dark"] .header-phone {
    color: rgba(250, 246, 240, 0.7);
  }
  #site-header[data-theme="dark"] .header-phone:hover {
    color: #8CBC94;
  }
  #site-header[data-theme="dark"] #mobile-menu-btn {
    color: rgba(250, 246, 240, 0.8);
  }
</style>
<header id="site-header" data-theme="light" class="fixed inset-x-0 top-0 z-40 transition-all duration-500 ease-premium">
  <div class="container-x flex h-20 items-center justify-between">
    <a href="/" class="flex items-center">
      <img src="/logo_immo.png" alt="immogutachter360°" height="64" class="h-16 w-auto" />
    </a>
    <nav class="hidden items-center gap-8 lg:flex">
      {NAV.map((item) => (
        <a
          href={item.href}
          class:list={[
            "text-sm transition-colors hover:text-green",
            path.startsWith(item.href) && item.href !== '/' ? 'text-green' : (item.href === '/' && path === '/' ? 'text-green' : 'text-ink')
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <a href={SITE.phoneHref} class="header-phone hidden text-sm text-ink hover:text-green md:inline" aria-label={SITE.phone}>
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M13.8 4.2a6 6 0 0 1 6 6" />
          <path d="M13.8 8.2a2 2 0 0 1 2 2" />
          <path d="M6.6 3.8 4.3 6.1c-.6.6-.8 1.5-.5 2.3a18 18 0 0 0 11.8 11.8c.8.3 1.7.1 2.3-.5l2.3-2.3c.5-.5.5-1.3 0-1.8l-3-3c-.5-.5-1.3-.5-1.8 0l-1.2 1.2a13 13 0 0 1-4-4l1.2-1.2c.5-.5.5-1.3 0-1.8l-3-3c-.5-.5-1.3-.5-1.8 0z" />
        </svg>
        <span class="sr-only">{SITE.phone}</span>
      </a>
      <a href="/kontakt" class="btn-primary">Kostenlose Anfrage</a>
      <button id="mobile-menu-btn" aria-label="Menü öffnen" class="lg:hidden p-1">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>
  <div id="mobile-menu" class="fixed inset-0 z-50 bg-cream lg:hidden" style="transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.22,1,0.36,1);">
    <div class="container-x flex h-20 items-center justify-between">
      <img src="/logo_immo.png" alt="immogutachter360°" height="56" class="h-14 w-auto" />
      <button id="mobile-menu-close" aria-label="Menü schließen" class="p-1">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 6l12 12M6 18L18 6"/></svg>
      </button>
    </div>
    <nav class="container-x flex flex-col gap-6 pt-12 text-3xl font-display">
      {NAV.map((item) => <a href={item.href} class="hover:text-green transition-colors">{item.label}</a>)}
    </nav>
    <div class="container-x mt-12">
      <a href="/kontakt" class="btn-primary w-full justify-center">Kostenlose Anfrage</a>
      <a href={SITE.phoneHref} class="mt-4 block text-center text-mute hover:text-green transition-colors" aria-label={SITE.phone}>
        <svg class="inline-block h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M13.8 4.2a6 6 0 0 1 6 6" />
          <path d="M13.8 8.2a2 2 0 0 1 2 2" />
          <path d="M6.6 3.8 4.3 6.1c-.6.6-.8 1.5-.5 2.3a18 18 0 0 0 11.8 11.8c.8.3 1.7.1 2.3-.5l2.3-2.3c.5-.5.5-1.3 0-1.8l-3-3c-.5-.5-1.3-.5-1.8 0l-1.2 1.2a13 13 0 0 1-4-4l1.2-1.2c.5-.5.5-1.3 0-1.8l-3-3c-.5-.5-1.3-.5-1.8 0z" />
        </svg>
        <span class="sr-only">{SITE.phone}</span>
      </a>
    </div>
  </div>
</header>
<div class="h-20"></div>
<script>
  const header = document.getElementById('site-header') as HTMLElement | null;
  const HEADER_H = 80;

  const update = () => {
    if (!header) return;
    const scrolled = window.scrollY > 20;

    if (!scrolled) {
      header.classList.remove('border-b', 'border-line', 'shadow-sm', 'backdrop-blur-md');
      header.style.background = '';
      header.dataset.theme = 'light';
      return;
    }

    const darkSections = document.querySelectorAll('[data-header-dark]');
    const isDark = [...darkSections].some(s => {
      const r = s.getBoundingClientRect();
      return r.top < HEADER_H && r.bottom > 0;
    });

    header.classList.add('border-b', 'shadow-sm', 'backdrop-blur-md');
    header.dataset.theme = isDark ? 'dark' : 'light';

    if (isDark) {
      header.style.background = 'rgba(24, 27, 49, 0.92)';
      header.classList.remove('border-line');
      header.style.borderColor = 'rgba(255,255,255,0.08)';
    } else {
      header.style.background = 'rgba(250, 246, 240, 0.95)';
      header.classList.add('border-line');
      header.style.borderColor = '';
    }
  };

  window.addEventListener('scroll', update, { passive: true });
  document.addEventListener('astro:page-load', update);
  update();

  const btn = document.getElementById('mobile-menu-btn');
  const close = document.getElementById('mobile-menu-close');
  const menu = document.getElementById('mobile-menu') as HTMLElement | null;
  btn?.addEventListener('click', () => {
    if (menu) { menu.style.transform = 'translateX(0)'; document.body.style.overflow = 'hidden'; }
  });
  const closeMenu = () => {
    if (menu) { menu.style.transform = 'translateX(100%)'; document.body.style.overflow = ''; }
  };
  close?.addEventListener('click', closeMenu);
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));
</script>
