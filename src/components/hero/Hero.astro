---
import HeroScene from '~/components/three/HeroScene.tsx';
import HeroHeadline from '~/components/hero/HeroHeadline.tsx';
import HeroProvenExpert from '~/components/ui/HeroProvenExpert.tsx';
import { SITE } from '~/lib/site';
---
<section class="relative flex min-h-[auto] flex-col overflow-hidden bg-cream lg:min-h-[92vh]">

  {/* Animated grain noise */}
  <div class="noise-overlay" aria-hidden="true"></div>

  {/* Ambient glow blobs — mouse-parallax via JS */}
  <div
    id="hero-glow-1"
    class="hero-glow-1 pointer-events-none absolute -right-32 -top-32 h-[300px] w-[300px] sm:h-[400px] sm:w-[400px] lg:h-[500px] lg:w-[500px] rounded-full blur-[120px] transition-transform duration-700 ease-out"
    style="background: radial-gradient(circle, rgba(140,188,148,0.15), transparent 70%)"
    aria-hidden="true"
  ></div>
  <div
    id="hero-glow-2"
    class="hero-glow-2 pointer-events-none absolute -bottom-32 -left-32 h-[250px] w-[250px] sm:h-[320px] sm:w-[320px] lg:h-[400px] lg:w-[400px] rounded-full blur-[100px] transition-transform duration-700 ease-out"
    style="background: radial-gradient(circle, rgba(197,222,201,0.18), transparent 70%)"
    aria-hidden="true"
  ></div>

  {/* Blueprint grid — right half, desktop only */}
  <svg
    class="pointer-events-none absolute right-0 top-0 hidden h-full w-1/2 lg:block"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <defs>
      <pattern id="blueprint" x="0" y="0" width="48" height="48" patternUnits="userSpaceOnUse">
        <path d="M 48 0 L 0 0 0 48" fill="none" stroke="rgba(24,27,49,0.055)" stroke-width="0.5"/>
        <circle cx="0" cy="0" r="1.2" fill="rgba(24,27,49,0.07)"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#blueprint)"/>
  </svg>

  {/* Main content */}
  <div class="container-x relative z-10 flex flex-1 items-start pt-10 pb-16 md:pt-12 md:pb-20 lg:pt-10 lg:pb-24">
    <div class="grid w-full items-center gap-8 md:gap-12 lg:grid-cols-[1fr_44%]">

      {/* Left: Copy */}
      <div class="relative z-10 max-w-xl lg:max-w-none">
        <p
          class="eyebrow opacity-0"
          style="animation: fadeUp 0.8s cubic-bezier(0.22,1,0.36,1) 0ms forwards"
        >
          DEKRA-zertifiziert · Düsseldorf · Deutschlandweit
        </p>

        <HeroHeadline client:load />

        <p
          class="mt-6 max-w-lg text-lg leading-relaxed opacity-0"
          style="color: var(--color-mute); animation: fadeUp 0.8s cubic-bezier(0.22,1,0.36,1) 0.55s forwards"
        >
          Verkehrswertgutachten, Immobilienbewertungen und Kaufberatung — präzise, gerichtsfest und transparent.<br />Ihr Sachverständiger aus Düsseldorf.
        </p>

        <div
          class="mt-8 flex flex-wrap items-center gap-4 opacity-0"
          style="animation: fadeUp 0.8s cubic-bezier(0.22,1,0.36,1) 0.68s forwards"
        >
          <button
            onclick="window.dispatchEvent(new CustomEvent('open-consultation-modal'))"
            class="btn-primary"
          >
            Kostenlose Ersteinschätzung
          </button>
          <a href={SITE.phoneHref} class="link-underline text-sm font-medium">{SITE.phone} anrufen →</a>
        </div>

        {/* Trust row — einheitliche Badge-Chips */}
        <div
          class="mt-7 flex flex-wrap items-center gap-2 opacity-0"
          style="animation: fadeUp 0.8s cubic-bezier(0.22,1,0.36,1) 0.82s forwards"
        >
          {/* Google Bewertungen */}
          <span
            class="inline-flex items-center gap-1.5 rounded-full border border-line bg-paper/80 px-3 text-xs font-medium text-ink"
            style="height:32px; backdrop-filter:blur(6px)"
          >
            <svg width="13" height="13" viewBox="0 0 488 488" aria-hidden="true">
              <path fill="#4285F4" d="M488 249c0-13-1-26-3-38H249v73h134c-6 30-23 55-49 72v59h79c46-43 73-106 73-166z"/>
              <path fill="#34A853" d="M249 488c67 0 123-22 164-60l-79-59c-22 15-51 23-85 23-65 0-121-44-140-103H28v61c41 82 126 138 221 138z"/>
              <path fill="#FBBC05" d="M109 289c-5-15-8-31-8-48s3-33 8-48v-61H28C10 167 0 207 0 249s10 82 28 117l81-77z"/>
              <path fill="#EA4335" d="M249 97c37 0 70 13 96 37l71-72C375 22 316 0 249 0 154 0 69 56 28 138l81 61c19-59 75-102 140-102z"/>
            </svg>
            <span style="color:#f59e0b">★★★★★</span>
            <span>4.9</span>
          </span>

          {/* ProvenExpert */}
          <HeroProvenExpert client:load />

          {/* DEKRA */}
          <a
            href="/ueber-uns"
            title="DEKRA-zertifizierter Sachverständiger"
            class="inline-flex items-center gap-2 rounded-full border border-line bg-paper/80 px-3 text-xs font-medium text-ink transition-all hover:border-green hover:text-green"
            style="height:32px; backdrop-filter:blur(6px)"
          >
            <img
              src="/dekra-siegel-zertifiziert-1_ergebnis.webp"
              alt="DEKRA"
              class="h-4 w-auto"
              loading="eager"
              decoding="async"
            />
            <span>DEKRA</span>
          </a>

          {/* Trennlinie */}
          <span class="mx-1 text-line select-none" aria-hidden="true">·</span>

          {/* Checkmarks */}
          <span class="inline-flex items-center gap-1.5 text-sm" style="color:var(--color-mute)">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-green"><polyline points="20 6 9 17 4 12"/></svg>
            Festpreis
          </span>
          <span class="inline-flex items-center gap-1.5 text-sm" style="color:var(--color-mute)">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-green"><polyline points="20 6 9 17 4 12"/></svg>
            Gerichtsfest
          </span>
        </div>
      </div>

      {/* Right: 3D Scene */}
      <div class="relative h-60 w-full sm:h-72 md:h-80 lg:h-auto lg:aspect-[4/5]">
        <HeroScene client:only="react" />
        <noscript>
          <div class="absolute inset-0 grid place-items-center text-mute">
            DEKRA-zertifizierte Immobilienbewertung
          </div>
        </noscript>
      </div>
    </div>
  </div>

  {/* Scroll indicator — desktop only */}
  <div
    class="relative z-10 hidden justify-center pb-10 opacity-0 lg:flex"
    style="animation: fadeUp 0.8s cubic-bezier(0.22,1,0.36,1) 1.1s forwards"
    aria-hidden="true"
  >
    <div class="scroll-indicator">
      <div class="scroll-indicator-line"></div>
    </div>
  </div>
</section>

<script>
  // Mouse parallax for hero glow blobs
  const g1 = document.getElementById('hero-glow-1');
  const g2 = document.getElementById('hero-glow-2');
  if (g1 && g2 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let tx1 = 0, ty1 = 0, tx2 = 0, ty2 = 0;
    let cx1 = 0, cy1 = 0, cx2 = 0, cy2 = 0;
    let raf = 0;
    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
    const tick = () => {
      cx1 = lerp(cx1, tx1, 0.06);
      cy1 = lerp(cy1, ty1, 0.06);
      cx2 = lerp(cx2, tx2, 0.06);
      cy2 = lerp(cy2, ty2, 0.06);
      g1.style.transform = `translate(${cx1}px, ${cy1}px)`;
      g2.style.transform = `translate(${cx2}px, ${cy2}px)`;
      raf = requestAnimationFrame(tick);
    };
    raf = requestAnimationFrame(tick);
    window.addEventListener('mousemove', (e) => {
      const nx = (e.clientX / window.innerWidth - 0.5);
      const ny = (e.clientY / window.innerHeight - 0.5);
      // blobs move opposite to each other for depth
      tx1 = nx * -28;
      ty1 = ny * -20;
      tx2 = nx * 22;
      ty2 = ny * 18;
    }, { passive: true });
    document.addEventListener('astro:before-preparation', () => cancelAnimationFrame(raf));
  }
</script>
