---
import BaseLayout from '~/layouts/BaseLayout.astro';
import FinalCTA from '~/components/sections/FinalCTA.astro';
import Reveal from '~/components/animations/Reveal.tsx';

const guides = [
  {
    title: 'Was kostet ein Verkehrswertgutachten?',
    description: 'Kosten, Einflussfaktoren und was in einem Festpreisangebot enthalten sein sollte.',
    href: '/blog/verkehrswertgutachten-kosten',
    category: 'Kosten & Preise',
    icon: '💶',
  },
  {
    title: 'Immobilienbewertung bei Erbschaft',
    description: 'Wann ein Gutachten Pflicht ist und wie Sie die Steuerlast legal minimieren.',
    href: '/blog/immobilienbewertung-erbschaft',
    category: 'Recht & Steuer',
    icon: '📜',
  },
  {
    title: 'Kaufberatung: Checkliste vor dem Notar',
    description: 'Was Sie vor dem Kauf prüfen sollten — und warum ein Sachverständiger schützt.',
    href: '/blog/kaufberatung-checkliste',
    category: 'Kaufen',
    icon: '🔑',
  },
  {
    title: 'Restnutzungsdauer: Steuern sparen als Vermieter',
    description: 'Wie ein Gutachten Ihre jährliche Abschreibung drastisch erhöhen kann.',
    href: '/blog/restnutzungsdauer-steuern-sparen',
    category: 'Recht & Steuer',
    icon: '🏛️',
  },
  {
    title: 'Schimmelpilz: Wer haftet wirklich?',
    description: 'Mieter, Vermieter, Bausubstanz — die rechtliche und technische Einordnung.',
    href: '/blog/schimmelgutachten-haftung',
    category: 'Baumängel',
    icon: '🔬',
  },
  {
    title: 'Immobilienbewertung bei Scheidung',
    description: 'Neutrale Bewertung als Basis für faire Einigung — was Sie wissen müssen.',
    href: '/blog/scheidung-immobilienbewertung',
    category: 'Recht & Steuer',
    icon: '⚖️',
  },
  {
    title: 'Energieausweis 2026: Pflicht & Fristen',
    description: 'Wer braucht welchen Energieausweis — und was droht ohne ihn.',
    href: '/blog/energieausweis-pflicht-2026',
    category: 'Energie',
    icon: '⚡',
  },
  {
    title: 'Bausachverständiger beauftragen',
    description: 'Wann lohnt sich ein Gutachter vor dem Kauf, bei Mängeln oder im Streit.',
    href: '/blog/bausachverstaendiger-wann',
    category: 'Baumängel',
    icon: '🏗️',
  },
];
---
<BaseLayout
  title="Ratgeber & Checklisten — Immobilien verstehen"
  description="Praxisratgeber zu Immobilienbewertung, Recht, Steuer und Baumängeln. Kostenlos, von Sachverständigen geschrieben."
>
  <section class="section-y bg-cream">
    <div class="container-x">
      <p class="eyebrow">Ratgeber</p>
      <h1 class="display-1 mt-6 max-w-4xl">Immobilien verstehen.<br/><span class="italic text-green">Klug entscheiden.</span></h1>
      <p class="mt-8 text-xl text-mute max-w-2xl leading-relaxed">Praxisnahes Fachwissen für Eigentümer, Käufer, Erben und Vermieter. Geschrieben von DEKRA-zertifizierten Sachverständigen.</p>
    </div>
  </section>
  <section class="section-y bg-paper">
    <div class="container-x">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {guides.map((g, i) => (
          <Reveal client:visible delay={i * 0.04}>
            <a href={g.href} class="card card-hover group flex h-full flex-col">
              <div class="text-4xl">{g.icon}</div>
              <span class="mt-6 text-xs uppercase tracking-[0.2em] text-green">{g.category}</span>
              <h2 class="mt-3 font-display text-xl group-hover:text-green transition-colors">{g.title}</h2>
              <p class="mt-3 flex-1 text-mute text-sm leading-relaxed">{g.description}</p>
              <span class="mt-6 inline-flex items-center gap-1 text-sm text-green">Lesen →</span>
            </a>
          </Reveal>
        ))}
      </div>
    </div>
  </section>
  <section class="section-y bg-cream">
    <div class="container-x">
      <div class="mx-auto max-w-2xl rounded-2xl border border-line bg-paper p-10 text-center">
        <div class="text-4xl">📋</div>
        <h2 class="mt-6 font-display text-3xl">Kostenlose Online-Bewertung</h2>
        <p class="mt-4 text-mute leading-relaxed">In 2 Minuten zu einer unverbindlichen Ersteinschätzung Ihrer Immobilie. Persönlich geprüft — keine Algorithmen.</p>
        <a href="/online-bewertung" class="btn-primary mt-8 inline-flex">Jetzt starten →</a>
      </div>
    </div>
  </section>
  <FinalCTA />
</BaseLayout>
