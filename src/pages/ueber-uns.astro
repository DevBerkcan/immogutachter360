---
import BaseLayout from '~/layouts/BaseLayout.astro';
import TrustBar from '~/components/sections/TrustBar.astro';
import FinalCTA from '~/components/sections/FinalCTA.astro';
import Reveal from '~/components/animations/Reveal.tsx';
import { personJsonLd } from '~/lib/seo';
---
<BaseLayout
  title="Über uns — Ihr Sachverständiger aus Düsseldorf"
  description="DEKRA-zertifizierter Immobiliengutachter aus Düsseldorf — persönlich, präzise, verlässlich. Mehr als 500 Gutachten, 8+ Jahre Erfahrung."
  image="/me.jpeg"
  jsonLd={[personJsonLd()]}
>

  {/* ── Hero ── */}
  <section class="section-y bg-cream">
    <div class="container-x grid gap-16 lg:grid-cols-2 lg:items-center">

      {/* Copy */}
      <div>
        <p class="eyebrow">Über uns</p>
        <h1 class="display-1 mt-6">
          Persönlich.<br/>Präzise.<br/>
          <span class="italic text-green">Verlässlich.</span>
        </h1>
        <p class="mt-10 text-xl leading-relaxed" style="color: var(--color-mute)">
          Seit über 8 Jahren begleiten wir Eigentümer, Käufer, Erben und Investoren bei den wichtigsten Immobilienentscheidungen ihres Lebens — mit Düsseldorfer Verwurzelung und deutschlandweitem Netzwerk.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/kontakt" class="btn-primary">Kostenlose Erstanfrage</a>
          <a href="/leistungen" class="link-underline text-sm font-medium">Alle Leistungen →</a>
        </div>
      </div>

      {/* Portrait mit Premium-Framing */}
      <Reveal client:visible>
        <div class="relative">
          {/* Decorative offset frame */}
          <div
            class="absolute -bottom-5 -right-5 h-full w-full rounded-2xl"
            style="background: rgba(140,188,148,0.1); border: 1px solid rgba(140,188,148,0.25)"
            aria-hidden="true"
          ></div>

          <div class="relative overflow-hidden rounded-2xl bg-cream">
            <img
              src="/me.jpeg"
              alt="DEKRA-zertifizierter Immobiliengutachter — Ihr persönlicher Ansprechpartner in Düsseldorf"
              class="w-full object-cover object-top"
              style="aspect-ratio: 3/4"
              loading="eager"
              decoding="async"
            />
          </div>

          {/* DEKRA badge */}
          <div class="absolute bottom-6 left-6 flex items-center gap-2 rounded-full bg-paper px-4 py-2.5 shadow-lg">
            <span class="h-2 w-2 rounded-full bg-green" style="box-shadow: 0 0 8px rgba(140,188,148,0.7)"></span>
            <span class="text-xs font-medium tracking-wider text-ink">DEKRA-zertifiziert seit 2016</span>
          </div>
        </div>
      </Reveal>
    </div>
  </section>

  <TrustBar />

  {/* ── Steckbrief ── */}
  <section class="section-y bg-paper">
    <div class="container-x grid gap-12 lg:grid-cols-2">
      <Reveal client:visible>
        <h2 class="display-2">Warum ein<br/><span class="italic text-green">zertifizierter</span><br/>Gutachter?</h2>
      </Reveal>
      <Reveal client:visible delay={0.1}>
        <div class="space-y-8">
          {[
            { n: '01', title: 'Rechtliche Anerkennung', text: 'Unsere Gutachten werden von Finanzämtern, Gerichten, Banken und Versicherungen bundesweit anerkannt. Kein anderes Bewertungsformat bietet diese Rechtssicherheit.' },
            { n: '02', title: 'DEKRA-Zertifizierung', text: 'Die DEKRA-Zertifizierung nach DIN EN ISO/IEC 17024 ist der Goldstandard in der Immobilienbewertung — unabhängig geprüft und regelmäßig erneuert.' },
            { n: '03', title: 'Unabhängigkeit', text: 'Als freier Sachverständiger haben wir kein Interesse am Kauf oder Verkauf Ihrer Immobilie. Unser einziges Ziel: der objektiv richtige Wert.' },
            { n: '04', title: 'Persönliche Begleitung', text: 'Sie sprechen immer direkt mit dem Sachverständigen — kein Call-Center, keine Weiterleitungen. Erste Einschätzung binnen 24 Stunden.' },
          ].map((item) => (
            <div class="flex gap-6 border-t border-line pt-6">
              <span class="font-display text-3xl font-light text-green shrink-0">{item.n}</span>
              <div>
                <h3 class="font-display text-xl">{item.title}</h3>
                <p class="mt-2 text-mute leading-relaxed">{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </Reveal>
    </div>
  </section>

  {/* ── Qualifikationen ── */}
  <section class="section-y bg-cream">
    <div class="container-x">
      <Reveal client:visible>
        <div class="max-w-xl">
          <p class="eyebrow">Qualifikationen</p>
          <h2 class="display-2 mt-4">Expertise, die<br/><span class="italic text-green">zählt.</span></h2>
        </div>
      </Reveal>
      <div class="mt-16 grid gap-4 md:grid-cols-3">
        {[
          { icon: '🏛️', title: 'DEKRA-Zertifizierung', detail: 'Sachverständiger für Immobilienbewertung, DIN EN ISO/IEC 17024' },
          { icon: '⚖️', title: 'IHK Düsseldorf', detail: 'Öffentlich bestellter und vereidigter Sachverständiger' },
          { icon: '📐', title: 'Bewertungsverfahren', detail: 'Vergleichswert-, Ertragswert- und Sachwertverfahren nach ImmoWertV 2021' },
          { icon: '🔬', title: 'Bau & Schaden', detail: 'Bausachverständiger für Schäden an Gebäuden und Schimmelpilz' },
          { icon: '⚡', title: 'Energieeffizienz', detail: 'Zugelassener Energieberater, Ausstellung Energieausweis Verbrauch & Bedarf' },
          { icon: '🏢', title: 'Wohn & Gewerbe', detail: 'Bewertung von Einfamilienhäusern, ETW, MFH, Gewerbe- und Sonderimmobilien' },
        ].map((q, i) => (
          <Reveal client:visible delay={i * 0.06}>
            <div class="card h-full">
              <div class="text-3xl">{q.icon}</div>
              <h3 class="mt-5 font-display text-xl">{q.title}</h3>
              <p class="mt-2 text-sm text-mute leading-relaxed">{q.detail}</p>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <FinalCTA />
</BaseLayout>
