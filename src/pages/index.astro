---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/hero/Hero.astro';
import TrustBar from '~/components/sections/TrustBar.astro';
import Services from '~/components/sections/Services.astro';
import Referenzen from '~/components/sections/Referenzen.astro';
import MarketData from '~/components/sections/MarketData.astro';
import Process from '~/components/sections/Process.astro';
import UseCases from '~/components/sections/UseCases.astro';
import About from '~/components/sections/About.astro';
import BlogTeaser from '~/components/sections/BlogTeaser.astro';
import Testimonials from '~/components/sections/Testimonials.astro';
import FAQ from '~/components/sections/FAQ.tsx';
import FinalCTA from '~/components/sections/FinalCTA.astro';
import { faqJsonLd, webSiteJsonLd, personJsonLd } from '~/lib/seo';
import { FAQS } from '~/lib/faqs';
---
<BaseLayout
  title="Immobiliengutachter Düsseldorf — DEKRA-zertifiziert"
  description="DEKRA-zertifizierte Immobiliengutachten, Verkehrswertgutachten und Kaufberatung aus Düsseldorf. Festpreis, schnell, bundesweit anerkannt."
  jsonLd={[webSiteJsonLd(), personJsonLd(), faqJsonLd(FAQS)]}
>
  <Hero />
  <TrustBar />
  <Services />
  <Referenzen />
  <MarketData />
  <Process />
  <UseCases />
  <About />
  <BlogTeaser />
  <Testimonials />
  <section class="section-y bg-paper">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow justify-center">FAQ</p>
        <h2 class="display-2 mt-4">Häufige Fragen.</h2>
      </div>
      <div class="mt-16">
        <FAQ client:visible />
      </div>
    </div>
  </section>
  <FinalCTA />
</BaseLayout>
