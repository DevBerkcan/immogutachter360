---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/hero/Hero.astro';
import VideoSection from '~/components/sections/VideoSection.astro';
import PainPoints from '~/components/sections/PainPoints.astro';
import TrustBar from '~/components/sections/TrustBar.astro';
import About from '~/components/sections/About.astro';
import MiniTestimonials from '~/components/sections/MiniTestimonials.astro';
import Services from '~/components/sections/Services.astro';
import Process from '~/components/sections/Process.astro';
import Referenzen from '~/components/sections/Referenzen.astro';
import MarketData from '~/components/sections/MarketData.astro';
import UseCases from '~/components/sections/UseCases.astro';
import Testimonials from '~/components/sections/Testimonials.astro';
import ValuationFunnel from '~/components/forms/ValuationFunnel.tsx';
import ReviewsSection from '~/components/sections/ReviewsSection.astro';
import FAQ from '~/components/sections/FAQ.tsx';
import FinalCTA from '~/components/sections/FinalCTA.astro';
import { faqJsonLd, webSiteJsonLd, personJsonLd, howToJsonLd } from '~/lib/seo';
import { FAQS, FAQ_CATEGORIES } from '~/lib/faqs';
import { CITIES } from '~/lib/cities';
---
<BaseLayout
  title="Immobiliengutachter Düsseldorf — DEKRA-zertifiziert"
  description="DEKRA-zertifizierte Immobiliengutachten, Verkehrswertgutachten und Kaufberatung aus Düsseldorf. Festpreis, schnell, bundesweit anerkannt."
  jsonLd={[
    webSiteJsonLd(),
    personJsonLd(),
    faqJsonLd(FAQS),
    howToJsonLd({
      name: 'Immobiliengutachten beauftragen — Schritt für Schritt',
      description: 'So läuft ein Immobiliengutachten bei immogutachter360 ab — von der Anfrage bis zur Übergabe.',
      url: '/',
      totalTime: 'P14D',
      steps: [
        {
          name: 'Anfrage stellen',
          text: 'Kostenlose erste Einschätzung per Telefon, E-Mail oder Online-Formular — Antwort binnen 24 Stunden.',
          url: '/kontakt',
        },
        {
          name: 'Ortstermin vereinbaren',
          text: 'Wir vereinbaren einen Besichtigungstermin und klären vorab die benötigten Unterlagen.',
          url: '/faq',
        },
        {
          name: 'Begehung & Dokumentation',
          text: 'Der Sachverständige besichtigt die Immobilie persönlich und erfasst alle wertrelevanten Faktoren.',
          url: '/ueber-uns',
        },
        {
          name: 'Gutachten erhalten',
          text: 'Innerhalb von 7–14 Werktagen erhalten Sie das fertige Gutachten mit persönlicher Erläuterung.',
          url: '/leistungen',
        },
      ],
    }),
  ]}
>
  <Hero />
  <VideoSection />

  {/* ── Bewertungs-Funnel ── */}
  <section class="section-y bg-cream">
    <div class="container-x max-w-3xl">
      <div class="mx-auto max-w-xl text-center">
        <p class="eyebrow justify-center">Kostenlose Ersteinschätzung</p>
        <h2 class="display-2 mt-4">
          Wie viel ist Ihre<br/>
          <span class="italic text-green">Immobilie wert?</span>
        </h2>
        <p class="mt-4 text-lg leading-relaxed" style="color: var(--color-mute)">
          In wenigen Schritten zur kostenlosen Ersteinschätzung — unverbindlich und ohne Verpflichtung.
        </p>
      </div>
      <div class="mt-12">
        <ValuationFunnel client:visible />
      </div>
    </div>
  </section>

  <About />
  <PainPoints />
  <TrustBar />
  <MiniTestimonials />
  <Services />
  <Process />
  <Referenzen />
  <MarketData />
  <UseCases />

  {/* ── Einzugsgebiet-Teaser ── */}
  <section class="section-y bg-cream">
    <div class="container-x text-center">
      <p class="eyebrow justify-center">Unser Einzugsgebiet</p>
      <h2 class="display-2 mt-4">
        Persönlich vor Ort —<br/>
        <span class="italic text-green">in ganz NRW.</span>
      </h2>
      <p class="mt-6 text-lg leading-relaxed mx-auto max-w-2xl" style="color: var(--color-mute)">
        Als DEKRA-zertifizierter Sachverständiger bin ich persönlich in der gesamten Metropolregion Rhein-Ruhr tätig.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        {CITIES.map(c => (
          <a
            href={`/immobiliengutachter-${c.slug}`}
            class="rounded-full border border-line px-4 py-2 text-sm transition-colors hover:border-green hover:text-green"
            style="color: var(--color-mute)"
          >
            {c.name}
          </a>
        ))}
      </div>
      <a href="/einzugsgebiet" class="link-underline mt-8 inline-block text-sm font-medium">
        Alle Standorte ansehen →
      </a>
    </div>
  </section>

  <section class="section-y bg-paper">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow justify-center">FAQ</p>
        <h2 class="display-2 mt-4">Häufige Fragen.</h2>
      </div>
      <div class="mt-16">
        <FAQ client:visible />
      </div>
      <div class="mt-10 text-center">
        <a href="/faq" class="link-underline text-sm font-medium">
          Alle {FAQ_CATEGORIES.flatMap(c => c.faqs).length} Fragen ansehen →
        </a>
      </div>
    </div>
  </section>

  <Testimonials />
  <ReviewsSection />
  <FinalCTA />
</BaseLayout>
